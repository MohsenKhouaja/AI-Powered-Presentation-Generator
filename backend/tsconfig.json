{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],
    "noImplicitAny": true,
    "strict": true
  },
  "include": [
    "app.ts",
    "api/**/*.ts",
    "config/**/*.ts",
    "database/**/*.ts",
    "middleware/**/*.ts",
    "routes/**/*.ts"
  ]
}
